{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "module": "esnext",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "../.tsbuild/test",
    "rootDir": "..",
    "tsBuildInfoFile": "../.tsbuild/test.tsbuildinfo",
    "types": ["jest", "node"]
  },
  "include": ["../app/**/*.ts", "../app/**/*.tsx", "./**/*.ts", "./**/*.tsx"],
  "exclude": ["../app/**/*.stories.tsx"]
}
