{
  "name": "open-book-shelf",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start": "bunx expo start --dev-client",
    "start:debug": "EXPO_PUBLIC_LOG_LEVEL=debug bunx expo start --dev-client",
    "ios": "bunx react-native run-ios",
    "android": "bunx react-native run-android --active-arch-only",
    "test:detox": "detox test -c ios.sim.debug",
    "build:detox": "detox build -c ios.sim.debug",
    "ci:test:detox": "detox test -c ios.sim.release -l verbose --cleanup",
    "ci:build:detox": "detox build -c ios.sim.release",
    "compile": "tsc --noEmit -p tsconfig.compile.json --pretty",
    "format": "biome format --write app test",
    "lint": "biome lint app test",
    "patch": "bunx patch-package",
    "test": "bun run test:unit && bun run test:detox",
    "test:watch": "bun test --watch app test",
    "test:unit": "bun test app test",
    "test:unit:watch": "bun test --watch app test",
    "adb": "adb reverse tcp:9090 tcp:9090 && adb reverse tcp:3000 tcp:3000 && adb reverse tcp:9001 tcp:9001 && adb reverse tcp:8081 tcp:8081",
    "postinstall": "node ./bin/postInstall",
    "bundle:ios": "bunx react-native bundle --entry-file index.js --platform ios --dev false --bundle-output ios/main.jsbundle --assets-dest ios",
    "bundle:android": "bunx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "release:ios": "echo 'Not implemented yet: release:ios. Use Xcode. More info: https://reactnative.dev/docs/next/publishing-to-app-store'",
    "release:android": "cd android && rm -rf app/src/main/res/drawable-* && ./gradlew assembleRelease && cd - && echo 'APK generated in ./android/app/build/outputs/apk/release/app-release.apk'",
    "clean": "bunx react-native-clean-project",
    "clean-all": "bunx react-native clean-project-auto",
    "expo:start": "USE_EXPO_GO=true bunx expo start",
    "expo:android": "USE_EXPO_GO=true bunx expo start --android",
    "expo:ios": "USE_EXPO_GO=true bunx expo start --ios",
    "expo:web": "bunx expo start --web",
    "debug:web": "EXPO_PUBLIC_LOG_LEVEL=debug bunx expo start --web",
    "desktop": "electrobun dev",
    "expo:build:detox": "detox build -c ios.sim.expo",
    "expo:test:detox": "./bin/downloadExpoApp.sh && detox test --configuration ios.sim.expo",
    "reactotron": "bun run adb && reactotron-app",
    "storybook-generate": "sb-rn-get-stories",
    "storybook-watch": "sb-rn-watcher",
    "storybook-native": "sb-rn-get-stories --config-path .storybook/native && EXPO_PUBLIC_STORYBOOK_ENABLED=true bunx expo start --dev-client",
    "storybook:web": "sb dev --config-dir .storybook/web -p 6006",
    "build-storybook": "build-storybook",
    "build:web": "bunx expo export --platform web --output-dir dist",
    "deploy:pages": "gh-pages -d dist -b gh-pages",
    "bundle-pdfjs": "bun run scripts/bundle-pdfjs.ts",
    "release:tag": "./bin/release-tag.sh"
  },
  "overrides": {
    "react-error-overlay": "6.0.9",
    "jsonfile": "6.1.0"
  },
  "dependencies": {
    "@expo-google-fonts/noto-serif-jp": "^0.2.3",
    "@expo-google-fonts/space-grotesk": "^0.2.3",
    "@expo/dev-server": "^0.5.5",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@gluestack-style/react": "^1.0.57",
    "@gluestack-ui/config": "^1.1.20",
    "@gluestack-ui/themed": "^1.1.73",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "^5.2.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@shopify/flash-list": "2.0.2",
    "apisauce": "^3.2.2",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^55.0.13",
    "expo-localization": "~17.0.8",
    "expo-screen-orientation": "~9.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-updates": "~29.0.16",
    "i18n-js": "^4.5.3",
    "js-md5": "^0.8.3",
    "mobx": "6.6.0",
    "mobx-react-lite": "^4.1.1",
    "mobx-state-tree": "5.1.5",
    "r2-opds-js": "^1.0.47",
    "r2-utils-js": "^1.0.43",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-native": "0.81.5",
    "react-native-blob-util": "^0.18.6",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-modalfy": "^3.7.0",
    "react-native-pdf": "^6.7.7",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.8.1",
    "react-pdf": "^8.0.2",
    "transliteration": "^2.6.1",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-decorators": "7.18.2",
    "@babel/runtime": "^7.29.2",
    "@biomejs/biome": "1.6.0",
    "@config-plugins/react-native-blob-util": "^6.0.0",
    "@config-plugins/react-native-pdf": "^6.0.0",
    "@storybook/addon-actions": "^8.6.18",
    "@storybook/addon-controls": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.18",
    "@storybook/addon-ondevice-actions": "^7.6.20",
    "@storybook/addon-ondevice-backgrounds": "^7.6.20",
    "@storybook/addon-ondevice-controls": "^7.6.20",
    "@storybook/addon-ondevice-knobs": "^7.6.20",
    "@storybook/addon-ondevice-notes": "^7.6.20",
    "@storybook/addon-react-native-web": "^0.0.23",
    "@storybook/jest": "^0.2.3",
    "@storybook/react": "^8.6.18",
    "@storybook/react-native": "^7.6.20",
    "@storybook/react-webpack5": "^8.6.18",
    "@storybook/testing-library": "^0.2.2",
    "@testing-library/react": "^14.3.1",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/react": "~19.1.17",
    "babel-loader": "^9.2.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "babel-plugin-react-native-web": "^0.19.13",
    "detox": "19.12.1",
    "detox-expo-helpers": "0.6.0",
    "electrobun": "latest",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.0.2",
    "patch-package": "6.4.7",
    "pdfjs-dist": "^4.10.38",
    "reactotron-core-client": "^2.9.9",
    "reactotron-mst": "^3.1.12",
    "reactotron-react-js": "^3.3.17",
    "reactotron-react-native": "^5.1.18",
    "storybook": "^8.6.18",
    "storybook-dark-mode": "^3.0.3",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "detox": {
    "test-runner": "jest",
    "runnerConfig": "./detox/config.json",
    "specs": "detox",
    "configurations": {
      "ios.sim.debug": {
        "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/OpenBookShelf.app",
        "build": "xcodebuild -workspace ios/OpenBookShelf.xcworkspace -scheme OpenBookShelf -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build -destination 'name=iPhone 14'",
        "type": "ios.simulator",
        "device": {
          "name": "iPhone 14",
          "os": "iOS 15.5"
        }
      },
      "ios.sim.release": {
        "binaryPath": "ios/build/Build/Products/Release-iphonesimulator/OpenBookShelf.app",
        "build": "xcodebuild -workspace ios/OpenBookShelf.xcworkspace -scheme OpenBookShelf -configuration Release -sdk iphonesimulator -derivedDataPath ios/build -destination 'name=iPhone 14'",
        "type": "ios.simulator",
        "device": {
          "name": "iPhone 14",
          "os": "iOS 15.5"
        }
      },
      "ios.sim.expo": {
        "binaryPath": "bin/Exponent.app",
        "type": "ios.simulator",
        "name": "iPhone 14"
      }
    }
  }
}
