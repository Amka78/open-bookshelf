{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./.tsbuild/storybook",
    "tsBuildInfoFile": "./.tsbuild/storybook.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["app/**/*.stories.tsx", ".storybook/**/*.ts", ".storybook/**/*.tsx"],
  "exclude": [
    ".expo",
    "android",
    "assets",
    "bin",
    "detox",
    "dist",
    "ignite",
    "ios",
    "node_modules",
    "bun.lockb",
    ".git",
    "app/**/*.test.ts",
    "app/**/*.test.tsx",
    "test"
  ]
}
